OPENAI_API_KEY=
TAVILY_API_KEY=
LANGGRAPH_STRICT_MSGPACK=true
# Optional tracing:
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=perplexity-at-home
# LANGSMITH_API_KEY=
# PERPLEXITY_AT_HOME_RUN_E2E=true

POSTGRES_HOST=localhost
POSTGRES_PORT=5442
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=perplexity_at_home
POSTGRES_SSLMODE=disable

PERPLEXITY_AT_HOME_DEFAULT_MODEL=openai:gpt-5.4
# Optional app settings:
# PERPLEXITY_AT_HOME_ENV=development
# PERPLEXITY_AT_HOME_DEBUG=true
# Optional per-workflow overrides:
# PERPLEXITY_AT_HOME_QUICK_SEARCH_MODEL=openai:gpt-5.4-mini
# PERPLEXITY_AT_HOME_PRO_SEARCH_MODEL=openai:gpt-5.4
# PERPLEXITY_AT_HOME_DEEP_RESEARCH_MODEL=openai:gpt-5.4
# PERPLEXITY_AT_HOME_DEEP_RESEARCH_RETRIEVAL_MODEL=openai:gpt-5.4
# Optional nested Postgres overrides:
# PERPLEXITY_AT_HOME_POSTGRES__HOST=localhost
# PERPLEXITY_AT_HOME_POSTGRES__PORT=5442
# PERPLEXITY_AT_HOME_POSTGRES__DATABASE=perplexity_at_home
# PERPLEXITY_AT_HOME_POSTGRES__USER=postgres
# PERPLEXITY_AT_HOME_POSTGRES__PASSWORD=postgres
# PERPLEXITY_AT_HOME_POSTGRES__SSLMODE=disable
